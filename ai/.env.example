# Copy this file to ai/.env and fill in the values you want to use.

# Required.
RUNPOD_API_KEY=replace-me

# Pod identity.
RUNPOD_POD_NAME=comfyui-hobby

# Set exactly one of these.
RUNPOD_TEMPLATE_ID=
RUNPOD_IMAGE_NAME=

# If you use RUNPOD_IMAGE_NAME, this command is wrapped as: bash -lc "$RUNPOD_START_COMMAND"
RUNPOD_START_COMMAND=python main.py --listen 0.0.0.0 --port 8188

# Cheap hobby defaults.
RUNPOD_CLOUD_TYPE=COMMUNITY
RUNPOD_INTERRUPTIBLE=false
RUNPOD_GPU_COUNT=1
RUNPOD_GPU_TYPE_IDS=Tesla T4,NVIDIA GeForce RTX 3070
RUNPOD_GPU_TYPE_PRIORITY=availability
RUNPOD_DATA_CENTER_IDS=
RUNPOD_DATA_CENTER_PRIORITY=availability
RUNPOD_CONTAINER_DISK_GB=50
RUNPOD_VOLUME_GB=30
RUNPOD_VOLUME_MOUNT_PATH=/workspace
RUNPOD_PORTS=8188/http,22/tcp
RUNPOD_SUPPORT_PUBLIC_IP=true
RUNPOD_MIN_RAM_PER_GPU=8
RUNPOD_MIN_VCPU_PER_GPU=4
RUNPOD_ALLOWED_CUDA_VERSIONS=

# ComfyUI API settings.
COMFYUI_PORT=8188
COMFYUI_HEALTH_PATH=/system_stats
RUNPOD_WAIT_TIMEOUT_SEC=900
RUNPOD_POLL_INTERVAL_SEC=5
COMFYUI_FETCH_TIMEOUT_SEC=1800
AUTO_STOP_AFTER_FETCH=true
